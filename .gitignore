# GitHub Token (SECURITY - DO NOT COMMIT)
Github Token.txt
*.token
*.secret
*.pem
*.key
*.p12
*.pfx

# AWS Credentials (CRITICAL - NEVER COMMIT)
.aws/
aws-credentials.json
credentials.json
