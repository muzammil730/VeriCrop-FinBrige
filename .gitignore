*.credentials

# Environment Variables (SECURITY)
.env
.env.*
.env.local
.env.development
.env.production
.env.test
.env.staging
!.env.example
!.env.template

# API Keys and Secrets
*apikey*
*api-key*
*secret*
*password*
config/secrets.yml
config/credentials.yml

